# Smart Pacing — protects OAuth accounts from ban detection
# Mode: "off" | "auto" | "human-sim"
#   off       = no pacing (max speed, for production apps)
#   auto      = smart minimum-gap + adaptive (default, zero delay for normal use)
#   human-sim = simulate human typing patterns (for personal agent use)
# SMART_PACING_MODE=auto

# Fingerprint Consistency — sanitizes outbound headers to match real clients
# Enabled by default. Strips leaked internal headers and ensures provider-specific
# headers are consistent with the impersonated client.
# FINGERPRINT_ENABLED=true

# Sticky Proxy — binds each OAuth account to one proxy IP permanently
# Prevents "same token, different IPs" detection pattern.
# Only applies when proxy pools are configured.
# STICKY_PROXY_ENABLED=true

# Optional: outbound proxy for upstream provider calls
