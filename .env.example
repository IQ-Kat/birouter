# Birouter environment configuration
# Copy this file to .env and adjust values for your setup.

# Data directory — where all persistent data is stored.
# Set this to any folder you want (e.g. D:\DataApp\birouter on Windows).
# If not set, defaults to:
#   Windows: %APPDATA%\birouter
#   macOS/Linux: ~/.birouter
DATA_DIR=D:\DataApp\birouter

# Server
PORT=20128
NODE_ENV=production

# Security (CHANGE THESE for real usage)
JWT_SECRET=change-me-to-a-long-random-secret
INITIAL_PASSWORD=change-me
API_KEY_SECRET=endpoint-proxy-api-key-secret
MACHINE_ID_SALT=endpoint-proxy-salt

# Logging
ENABLE_REQUEST_LOGS=false

# Optional: outbound proxy for upstream provider calls
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890
# ALL_PROXY=socks5://127.0.0.1:7890
# NO_PROXY=localhost,127.0.0.1
